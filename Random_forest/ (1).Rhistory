ts_decompose(USVSales)
library(h2o); library(TSstudio); library(lubridate)
data("USVSales")
ts_info(USVSales)
ts_plot(USVSales,
title = 'Venta de vehículos en EEUU entre 1976 y 2019',
Xtitle = 'Años',
Ytitle = 'Miles de unidades')
ts_decompose(USVSales)
USV_detrend <- USVSales - decompose(USVSales)$trend
ts_seasonal(USV_detrend, type = 'box')
ts_lags(USVSales, lags = c(12,24,36))
df <- ts_to_prophet(window(USVSales, start = c(2010,1)))
names(df) <- c('date', 'y')
head(df)
ts_plot(df,
title = 'Ventas mensuales desde 2010',
Xtitle = 'Años',
Ytitle = 'Miles de unidades')
library(dplyr)
df <- df %>%
mutate(month = factor(month(date, label = T, ordered = F),
lag12 = lag(y, n = 12)) %>%
filter(!is.na(lag12)))
